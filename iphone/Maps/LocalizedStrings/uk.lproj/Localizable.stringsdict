			<key>zero</key>
			<string>%lld треків</string>
			<key>one</key>
			<string>%lld трек</string>
			<key>few</key>
			<string>%lld треки</string>
			<key>many</key>
			<string>%lld треків</string>
		</dict>
	</dict>
	<key>population</key>
