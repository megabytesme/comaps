<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  tools:visibility="visible"
  style="@style/PlacePageItemFrame">

  <com.google.android.material.imageview.ShapeableImageView
    android:id="@+id/icon"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/margin_base"
    app:srcCompat="@drawable/ic_opening_hours"
    app:tint="?iconTint"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="@id/oh_today_label"
    app:layout_constraintBottom_toBottomOf="@id/oh_today_label"/>

  <androidx.constraintlayout.widget.Barrier
    android:id="@+id/oh_header_barrier"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:barrierDirection="bottom"
    app:barrierMargin="@dimen/margin_half"
    app:constraint_referenced_ids="oh_today_label,oh_today_shifts"/>

    <com.google.android.material.textview.MaterialTextView
      android:id="@+id/oh_today_label"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:layout_marginStart="@dimen/margin_base"
      android:textAppearance="@style/MwmTextAppearance.PlacePage"
      tools:text="@string/today"
      android:text="@string/today"
      app:layout_constraintStart_toEndOf="@id/icon"
      app:layout_constraintTop_toTopOf="parent"
      tools:visibility="visible"/>

  <LinearLayout
    android:id="@+id/oh_today_shifts"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="6dp"
    android:layout_marginStart="@dimen/margin_base"
    app:layout_constraintStart_toEndOf="@id/oh_today_label"
    app:layout_constraintEnd_toStartOf="@id/dropdown_icon"
    app:layout_constraintTop_toTopOf="parent"/>

  <com.google.android.material.imageview.ShapeableImageView
    android:contentDescription="@null"
    android:id="@+id/dropdown_icon"
    android:layout_width="30dp"
    android:layout_height="30dp"
    android:layout_marginBottom="1dp"
    android:layout_marginEnd="@dimen/neg_margin_quarter"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="@id/oh_header_barrier"
    app:srcCompat="@drawable/ic_expand_more"
    android:visibility="gone"
    app:tint="?iconTint"
    tools:visibility="visible" />

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/rw__full_opening_hours"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    app:layout_goneMarginTop="0dp"
    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
    tools:itemCount="3"
    tools:listitem="@layout/place_page_opening_hours_item"
    app:layout_constraintStart_toStartOf="@id/oh_today_label"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/oh_header_barrier"/>

  <com.google.android.material.textview.MaterialTextView
    android:id="@+id/oh_check_date"
    style="@style/MwmTextAppearance.Caption"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:textAppearance="@style/MwmTextAppearance.Body4"
    android:textAlignment="viewStart"
    android:visibility="gone"
    tools:visibility="visible"
    app:layout_constraintStart_toStartOf="@id/oh_today_label"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/rw__full_opening_hours"
    tools:text="Confirmed 2 months ago"/>
</androidx.constraintlayout.widget.ConstraintLayout>
